{
  "name": "elasticsearch",
  "version": "0.3.0",
  "mcpServers": {
    "elastic-agent-builder": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "${ELASTIC_MCP_URL}",
        "--header",
        "Authorization:${AUTH}"
      ],
      "env": {
        "AUTH": "ApiKey ${ELASTIC_API_KEY}"
      }
    }
  },
  "contextFileName": "GEMINI.md"
}
